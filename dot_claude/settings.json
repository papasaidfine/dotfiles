{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "EDITOR": "vi",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(sort *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(whoami)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(uv *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(docker *)",
      "Bash(docker-compose *)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(dd if=*)",
      "Bash(mkfs *)",
      "Bash(mkfs.*)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "sandbox": {
    "excludedCommands": [
      "docker *",
      "docker-compose *"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true,
  "model": "sonnet"
}
